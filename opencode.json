{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "alembic-migration": "allow",
      "stripe-checkout-flow": "allow",
      "saia-chatbot-prompt": "allow",
      "json-import-validator": "allow",
      "nextjs-app-router-page": "allow",
      "docker-compose-stack": "allow",
      "tailwind-design-system": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "frontend/node_modules/**",
      "frontend/.next/**",
      "frontend/out/**",
      "frontend/tsconfig.tsbuildinfo",
      "frontend/package-lock.json",
      "frontend/.turbo/**",
      "frontend/coverage/**",
      "backend/venv/**",
      "backend/.venv/**",
      "backend/__pycache__/**",
      "backend/**/__pycache__/**",
      "backend/.pytest_cache/**",
      "backend/.mypy_cache/**",
      "backend/htmlcov/**",
      "backend/coverage.xml",
      "**/*.pyc",
      "**/*.pyo",
      "**/*.pyd",
      "**/.DS_Store",
      "**/Thumbs.db",
      "**/*.log",
      "**/logs/**",
      "**/.env",
      "**/.env.local",
      "**/.env.*.local",
      ".git/**",
      ".opencode/skills/**",
      "**/dist/**",
      "**/build/**",
      "**/*.egg-info/**",
      "**/.next/**"
    ]
  }
}
